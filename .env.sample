# Client ID (safe to expose; also visible in the Spotify login URL)
NUXT_PUBLIC_SPOTIFY_CLIENT_ID=

# Client secret — server-only (no PUBLIC prefix)
NUXT_SPOTIFY_CLIENT_SECRET=

# Encrypts the HttpOnly session cookie (long random string; never commit or expose)
NUXT_SESSION_SECRET=

# --- Cloudflare Workers (production) ---
# This value is read at RUNTIME from the Worker, not baked into the build.
# Set it once per Worker (it persists across deploys):
#   yarn cf:secret:session
#   # or: npx wrangler --cwd .output secret put NUXT_SESSION_SECRET
# Or: Workers & Pages → your Worker → Settings → Variables and Secrets → Secrets.
# Do NOT use a new random secret on every CI deploy — use one stable value and
# store it in Cloudflare Secrets (or a GitHub Actions secret + wrangler secret put
# in CI once).
#
# Local preview with wrangler (optional): put the same vars in .output/.dev.vars
# (see `.gitignore`; this file is gitignored).
