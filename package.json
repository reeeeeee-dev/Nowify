{
  "name": "Nowify",
  "version": "2.0.1",
  "private": true,
  "bugs": "https://github.com/jonashcroft/Nowify/issues/",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/jonashcroft/Nowify/",
    "type": "git"
  },
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "deploy:cloudflare": "nuxt build && wrangler --cwd .output deploy",
    "preview:cloudflare": "nuxt build && wrangler --cwd .output dev",
    "cf:secret:session": "wrangler --cwd .output secret put NUXT_SESSION_SECRET",
    "postinstall": "nuxt prepare",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "nuxt": "^4.4.2",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.54.0"
  }
}
